{
    "name": "aureuserp/mcp",
    "description": "MCP integration plugin for AureusERP.",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Aureus ERP",
            "email": "support@aureuserp.in"
        }
    ],
    "require": {
        "php": "^8.2",
        "laravel/framework": "^11.0",
        "laravel/mcp": "^0.5",
        "laravel/passport": "^13.0",
        "filament/filament": "^4.0"
    },
    "extra": {
        "laravel": {
            "providers": [
                "Webkul\\Mcp\\McpServiceProvider"
            ],
            "aliases": {}
        }
    },
    "autoload": {
        "psr-4": {
            "Webkul\\Mcp\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Webkul\\Mcp\\Tests\\": "tests/"
        }
    }
}
